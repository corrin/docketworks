# Claude Code: ignore everything under .claude/ except the handful of tracked files.
# When this repo is a user's $HOME (UAT/PROD), Claude writes session/history/cache
# state into .claude/ — we don't want to enumerate every subdir by name.
.claude/*
!.claude/settings.json
!.claude/skills/
.claude.json

