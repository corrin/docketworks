# WARNING: Keep this file in sync with
# scripts/server/templates/env-instance.template. Any setting added here must
# also be added to the instance template so newly-created server instances boot.

# Django Core Settings
DEBUG=True
SECRET_KEY=CREATE_USING_from_django.core.management.utils_import_get_random_secret_key
DJANGO_ENV=local
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.ngrok-free.app

# Database Configuration (PostgreSQL)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=dw_yourco_dev
DB_USER=dw_yourco_dev
DB_PASSWORD=your_secure_password_here
DB_HOST=/var/run/postgresql
DB_PORT=5432
# Used by `manage.py backport_data_backup`. Must end in "_scrub".
# Auto-provisioned by scripts/server/instance.sh alongside the main DB.
# For ad-hoc dev setups: `sudo -u postgres createdb <DB_NAME>_scrub -O <DB_USER>`.
SCRUB_DB_NAME=dw_yourco_dev_scrub
# Pytest connects as a separate role that owns test_dw_yourco_dev only.
# Auto-provisioned by scripts/server/instance.sh on UAT/prod servers.
# For ad-hoc dev setups, create both manually:
#   sudo -u postgres psql -c "CREATE ROLE dw_yourco_dev_test WITH LOGIN PASSWORD '<pwd>';"
#   sudo -u postgres createdb test_dw_yourco_dev -O dw_yourco_dev_test
TEST_DB_USER=dw_yourco_dev_test
TEST_DB_PASSWORD=your_secure_test_password_here

# Used by settings.py for both CORS and CSRF trusted origins
CORS_ALLOWED_ORIGINS=https://your-domain.ngrok-free.app

# Tunnel configuration for development (single ngrok tunnel to Vite on port 5173)
NGROK_AUTH_TOKEN=your_ngrok_auth_token_here
APP_DOMAIN=your-domain.ngrok-free.app

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Django Site Domain (used for absolute URLs in production-like environments)
DJANGO_SITE_DOMAIN=your-domain.ngrok-free.app

# Xero Integration
ACCOUNTING_BACKEND=xero
XERO_DEFAULT_USER_ID=YOUR_XERO_USER_ID_FOR_TIME_ENTRIES
XERO_SYNC_PROJECTS=False
XERO_SCOPES="offline_access openid profile email accounting.contacts accounting.invoices accounting.attachments accounting.settings projects payroll.timesheets payroll.payruns payroll.payslip payroll.employees payroll.settings"
XERO_AUTOMATED_DAY_FLOOR=100

# JWT Configuration
ENABLE_JWT_AUTH=True

# Frontend URL for links back to the frontend application
FRONT_END_URL=https://your-domain.ngrok-free.app

# Dropbox workflow folder - use quotes if path contains spaces
DROPBOX_WORKFLOW_FOLDER="/path/to/your/Dropbox/Workflow Folder"
MEDIA_ROOT=/var/lib/docketworks/mediafiles
LOG_DIR=/var/log/docketworks

# Google Cloud Platform credentials (for Sheets API / AI pricing)
GCP_CREDENTIALS=/path/to/google-service-account-key.json

# Google Maps API key (address validation)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Steel & Tube Integration (supplier pricing scraper)
STEEL_TUBE_USERNAME=REQUEST_FROM_STEEL_AND_TUBE
STEEL_TUBE_PASSWORD="REQUEST_FROM_STEEL_AND_TUBE"

# Phone call history / recording archive
PHONE_CALL_DOWNLOADS_ENABLED=False
PHONE_PROVIDER_RECORDING_DELETION_ENABLED=False
PHONE_PROVIDER_BASE_URL=https://phone-provider.example.invalid/
PHONE_PROVIDER_USERNAME=REQUEST_FROM_PHONE_PROVIDER
PHONE_PROVIDER_PASSWORD="REQUEST_FROM_PHONE_PROVIDER"
PHONE_PROVIDER_ACCOUNT_CODE=REQUEST_FROM_PHONE_PROVIDER
PHONE_OWN_NUMBERS=+6490000000,+64210000000
PHONE_RECORDING_STORAGE_ROOT=/var/lib/docketworks/phone-recordings

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password_here
DEFAULT_FROM_EMAIL=your_email@gmail.com
EMAIL_BCC=admin@yourcompany.com
DJANGO_ADMINS=admin@yourcompany.com

# Feature Flags
DEBUG_PAYLOAD=False
SKIP_VERSION_CHECK=False
JOB_DELTA_SOFT_FAIL=True

# Session replay diagnostics
SESSION_REPLAY_RETENTION_DAYS=14
SESSION_REPLAY_STORAGE_ROOT=/var/lib/docketworks/session-replays
