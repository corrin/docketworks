# Django Core Settings
DEBUG=True
SECRET_KEY=CREATE_USING_from_django.core.management.utils_import_get_random_secret_key
DJANGO_ENV=local
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.ngrok-free.app

# Database Configuration (PostgreSQL)
DB_NAME=dw_msm_dev
DB_USER=dw_msm_dev
DB_PASSWORD=your_secure_password_here
TEST_DB_USER=dw_test
TEST_DB_PASSWORD=dw_test

# Used by settings.py for both CORS and CSRF trusted origins (single-origin, no cross-domain)
CORS_ALLOWED_ORIGINS=https://your-domain.ngrok-free.app

# Tunnel configuration for development (single ngrok tunnel to Vite on port 5173)
TUNNEL_URL=https://your-domain.ngrok-free.app
NGROK_AUTH_TOKEN=your_ngrok_auth_token_here

# Django Site Domain (used for absolute URLs)
DJANGO_SITE_DOMAIN=your-domain.ngrok-free.app

# Xero Integration
XERO_CLIENT_ID=YOUR_XERO_CLIENT_ID
XERO_CLIENT_SECRET=YOUR_XERO_CLIENT_SECRET
XERO_REDIRECT_URI=https://your-domain.ngrok-free.app/api/xero/oauth/callback/
XERO_DEFAULT_USER_ID=YOUR_XERO_USER_ID_FOR_TIME_ENTRIES  # Find with: python manage.py xero --users
XERO_SYNC_PROJECTS=False

# JWT Configuration
ENABLE_JWT_AUTH=True

# App domain configuration
APP_DOMAIN=your-domain.ngrok-free.app

# Path to Dropbox workflow folder - use quotes if path contains spaces
DROPBOX_WORKFLOW_FOLDER="C:\Users\YourUser\Dropbox\Your Workflow Folder"

# Google Sheets API credentials
GCP_CREDENTIALS="/path/to/google-service-account-key.json"

# Google Maps API key for address validation
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Steel Tube Integration
STEEL_TUBE_USERNAME=REQUEST_FROM_STEEL_AND_TUBE
STEEL_TUBE_PASSWORD="REQUEST_FROM_STEEL_AND_TUBE"

# Email Configuration (for password reset, etc.)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password_here
DEFAULT_FROM_EMAIL=your_email@gmail.com
EMAIL_BCC=admin@yourcompany.com
DJANGO_ADMINS=admin@yourcompany.com

# Django environment setting
DJANGO_ENV=production_like


# Xero webhook verification key
XERO_WEBHOOK_KEY=XERO_WEBHOOK_SIGNING_KEY_GOES_HERE


# Frontend URL for links back to the frontend application
FRONT_END_URL=https://your-domain.ngrok-free.app

# Enable weekend timesheets
WEEKEND_TIMESHEETS_ENABLED=True

# Enable detailed payload logging for debugging (only in development)
DEBUG_PAYLOAD=False

# Enable soft fail during delta validation (defaults to True)
JOB_DELTA_SOFT_FAIL=True
