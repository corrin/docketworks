{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Frontend Dev Server",
      "type": "process",
      "command": "${env:HOME}/.nvm/nvm-exec",
      "args": ["npm", "run", "dev"],
      "hide": true,
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "ready in"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Frontend Manual Dev Server",
      "type": "process",
      "command": "${env:HOME}/.nvm/nvm-exec",
      "args": ["npm", "run", "manual:dev"],
      "hide": true,
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vitepress",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "vitepress",
          "endsPattern": "http://localhost"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Ngrok Tunnels",
      "type": "shell",
      "command": "ngrok start dev --config ${workspaceFolder}/ngrok.yml",
      "hide": true,
      "isBackground": true,
      "problemMatcher": {
        "owner": "ngrok",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "started tunnel"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Celery Worker",
      "type": "shell",
      "command": "poetry run celery -A docketworks worker --concurrency=4 --loglevel=info",
      "hide": true,
      "isBackground": true,
      "problemMatcher": {
        "owner": "celery",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "celery@.* ready"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Celery Beat",
      "type": "shell",
      "command": "poetry run celery -A docketworks beat --loglevel=info --scheduler django_celery_beat.schedulers:DatabaseScheduler",
      "hide": true,
      "isBackground": true,
      "problemMatcher": {
        "owner": "celery-beat",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "beat: Starting\\.\\.\\."
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Start Hotfix Environment",
      "dependsOn": [
        "Frontend Dev Server",
        "Frontend Manual Dev Server",
        "Ngrok Tunnels",
        "Celery Worker",
        "Celery Beat"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "Rebuild Schema",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/update_schema.sh",
      "hide": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
