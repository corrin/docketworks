{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Redis Server",
      "type": "shell",
      "command": "REDIS_HOST=\"${env:REDIS_HOST}\"; REDIS_PORT=\"${env:REDIS_PORT}\"; if [ -z \"$REDIS_HOST\" ]; then REDIS_HOST=127.0.0.1; fi; if [ -z \"$REDIS_PORT\" ]; then REDIS_PORT=6379; fi; redis-cli -h \"$REDIS_HOST\" -p \"$REDIS_PORT\" ping || redis-server --port \"$REDIS_PORT\"",
      "isBackground": true,
      "problemMatcher": {
        "owner": "redis",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "PONG|Ready to accept connections"
        }
      },
      "presentation": {
        "group": "dev",
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Frontend Dev Server",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "ready in"
        }
      },
      "presentation": {
        "group": "dev",
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Frontend Manual Dev Server",
      "type": "shell",
      "command": "npm run manual:dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vitepress",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "vitepress",
          "endsPattern": "http://localhost"
        }
      },
      "presentation": {
        "group": "dev",
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Ngrok Tunnels",
      "type": "shell",
      "command": "ngrok start --config ${workspaceFolder}/ngrok.yml --all",
      "isBackground": true,
      "problemMatcher": {
        "owner": "ngrok",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "started tunnel"
        }
      },
      "presentation": {
        "group": "dev",
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Celery Worker",
      "type": "shell",
      "command": "poetry run celery -A docketworks worker --concurrency=4 --loglevel=info",
      "isBackground": true,
      "problemMatcher": {
        "owner": "celery",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "celery@.* ready"
        }
      },
      "presentation": {
        "group": "dev",
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Celery Beat",
      "type": "shell",
      "command": "poetry run celery -A docketworks beat --loglevel=info --scheduler django_celery_beat.schedulers:DatabaseScheduler",
      "isBackground": true,
      "problemMatcher": {
        "owner": "celery-beat",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "beat: Starting\\.\\.\\."
        }
      },
      "presentation": {
        "group": "dev",
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Start Dev Environment",
      "dependsOn": [
        "Redis Server",
        "Frontend Dev Server",
        "Frontend Manual Dev Server",
        "Ngrok Tunnels",
        "Celery Worker",
        "Celery Beat"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "Rebuild Schema",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/update_schema.sh",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
