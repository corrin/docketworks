#!/bin/bash
# Pre-push hook: backend mypy gate + frontend checks
set -e

bash "$(git rev-parse --show-toplevel)/scripts/check_mypy.sh"
bash "$(git rev-parse --show-toplevel)/scripts/check_requirements.sh"

cd "$(git rev-parse --show-toplevel)/frontend"
npm run check:typed-router
npm run test:unit
npm run lint
npm run type-check
npm run check:typed-router:build
npm run check:workflow-format
