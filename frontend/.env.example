VITE_ALLOWED_HOSTS=your-domain.ngrok-free.app,your-uat-domain.com
VITE_UAT_URL=https://your-uat-domain.com

# Authentication method: 'cookie' or 'bearer'
# Cookie auth works for both dev and prod (same-origin via Vite proxy)
VITE_AUTH_METHOD=cookie

# Weekend timesheets feature flag
VITE_WEEKEND_TIMESHEETS_ENABLED=false
XERO_USERNAME=username@example.com
XERO_PASSWORD="password"
