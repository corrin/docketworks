{
  "name": "frontend-jobs-manager",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "gen:api": "node ./scripts/gen-api.js",
    "update-schema": "npx prettier --write schema.yml && npm run gen:api",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "manual:dev": "vitepress dev manual --port 5174",
    "manual:build": "vitepress build manual",
    "manual:preview": "vitepress preview manual",
    "manual:pdf": "vitepress-export-pdf export manual",
    "manual:screenshots": "npx tsx scripts/capture-screenshots.ts"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@internationalized/date": "^3.8.2",
    "@kodeglot/vue-calendar": "^1.5.0",
    "@tailwindcss/vite": "^4.1.8",
    "@tanstack/vue-table": "^8.21.3",
    "@types/event-source-polyfill": "^1.0.5",
    "@types/quill": "^2.0.14",
    "@types/sortablejs": "^1.15.8",
    "@types/uuid": "^10.0.0",
    "@unovis/vue": "^1.5.2",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^13.9.0",
    "@zodios/core": "^10.9.6",
    "ag-grid-community": "^35.1.0",
    "ag-grid-vue3": "^33.3.2",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dayjs": "^1.11.20",
    "dompurify": "^3.3.3",
    "event-source-polyfill": "^1.0.31",
    "js-cookie": "^3.0.5",
    "lodash-es": "^4.17.23",
    "lucide-vue-next": "^0.513.0",
    "openapi-zod-client": "^1.18.3",
    "pdf-vue3": "^1.0.12",
    "pinia": "^3.0.1",
    "qs": "^6.14.2",
    "quill": "^2.0.3",
    "reka-ui": "^2.8.2",
    "sortablejs": "^1.15.6",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.3.4",
    "uuid": "^11.1.0",
    "vaul-vue": "^0.4.1",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.13",
    "vue-advanced-chat": "^2.1.0",
    "vue-router": "^5.0.3",
    "vue-sonner": "^2.0.1",
    "zod": "^3.25.55"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@tsconfig/node22": "^22.0.1",
    "@types/adm-zip": "^0.5.7",
    "@types/dompurify": "^3.2.0",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "adm-zip": "^0.5.16",
    "dotenv": "^17.2.3",
    "eslint": "^9.22.0",
    "eslint-plugin-vue": "~10.0.0",
    "happy-dom": "^20.0.11",
    "jiti": "^2.4.2",
    "lint-staged": "^16.1.2",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.5.3",
    "puppeteer": "^24.22.3",
    "tsx": "^4.21.0",
    "typescript": "~5.8.0",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vitepress": "^1.6.4",
    "vitepress-export-pdf": "^1.0.0",
    "vitest": "^4.0.15",
    "vue-tsc": "^2.2.8"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,css}": [
      "prettier --write"
    ]
  }
}
